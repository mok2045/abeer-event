<Files "data.json">
  Require all denied
</Files>
Options -Indexes

# Never cache HTML or the service worker — always fetch fresh
<IfModule mod_headers.c>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
  <FilesMatch "^sw\.js$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Disable LiteSpeed server-side page cache
<IfModule LiteSpeed>
  RewriteEngine On
  RewriteRule .* - [E=Cache-Control:no-cache]
  RewriteRule .* - [E=no-cache:1]
</IfModule>

# Tell CDN/proxy caches never to store responses
<IfModule mod_headers.c>
  <FilesMatch "\.(html|htm|css|js)$">
    Header append Surrogate-Control "no-store"
  </FilesMatch>
</IfModule>
